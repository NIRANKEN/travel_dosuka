# Cloud Run デプロイ設定
# このファイルを .env.cloudrun にコピーして使用してください
# cp .env.cloudrun.example .env.cloudrun

# GCP プロジェクトID（必須）
PROJECT_ID=your-project-id

# Cloud Run サービス名（オプション、デフォルト: langchain-tutorial）
SERVICE_NAME=langchain-tutorial

# デプロイ先リージョン（オプション、デフォルト: asia-northeast1）
REGION=asia-northeast1

# Google API Key（必須）
GOOGLE_API_KEY=your-google-api-key
